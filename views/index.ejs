<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%-include("partials/nav") %>
    <h1><%=title %></h1>
         <% if (locals.user) {%>
    <div class="welcome">
        <h1>WELCOME BACK <span class="user"><%= user.username %></span></h1>
        <a href="/log-out">LOG OUT</a>
        
        <%-include("partials/folderForm") %>
        <% if(locals.folders){ %>
        <% folders.forEach(folder => { %>
            <% 
                 %>
            <div class="folderBlock">

                    <a href="/folder"><%=folder.folderName%></a>
                     <button class="updateBtn" data-id="<%=folder.id %>">Update</button>
                     <form hidden="true" class="updateForm" method="post" action="/folder/update?id=<%=folder.id %>" data-id="<%=folder.id %>" >
                          <label for="folder">Update Folder Name:</label>
                          <input type="text" name="folderName" id="folder" required>
                          <button type="submit">Submit update</button>
                     </form>
               <a href="/folder/delete?id=<%=folder.id %>"> <button>Delete</button></a>
    
            </div>
         
       <% }); %>
        <% } %>
    </div>
  <% }  %>
    <p>
        Lorem ipsum, dolor sit amet consectetur adipisicing elit.
        Unde esse quam perferendis, architecto sed provident
        molestiae voluptatibus atque eaque voluptates
         exercitationem dolores maxime animi cumque dignissimos
          ex nostrum aliquid laboriosam.
    </p>
     <script>
        const updateBtn=document.querySelectorAll(".updateBtn");
        const updateForm=document.querySelectorAll(".updateForm");
        updateBtn.forEach((btn)=>{
            btn.addEventListener("click",(e)=>{
            let btnId= e.target.getAttribute('data-id');
            updateForm.forEach((form)=>{
                let formId=form.getAttribute("data-id");
                if(formId == btnId){
                     if(form.hidden ==true){
                        form.hidden=false;
                     }else{
                        form.hidden=true;
                         }
                }
            })
        })
        })
    </script> 
</body>
</html>