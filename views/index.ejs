<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%-include("partials/nav") %>
    <h1><%=title %></h1>
         <% if (locals.user) {%>
    <div class="welcome">
        <h1>WELCOME BACK <span class="user"><%= user.username %></span></h1>
        <a href="/log-out">LOG OUT</a>
        
        <%-include("partials/folderForm") %>
        <% if(locals.folders){ %>
        <% folders.forEach(folder => { %>
            <div class="folderBlock">
    
                <a href="/folder"><%=folder.folderName %></a>
                 <a href="/folder/update?id=<%=folder.id %>"><button>Update</button></a>
               <a href="/folder/delete?id=<%=folder.id %>"> <button>Delete</button></a>
    
            </div>
       <% }); %>
        <% } %>
    </div>
  <% }  %>
